# Copy this to .env.development or .env.production and fill in the values.
#
# VITE_USE_MOCK=true          → use in-memory mock data (default for dev)
# VITE_USE_MOCK=false         → call real REST API (set for staging / prod)
#
# VITE_API_BASE_URL           → base URL for the real backend
#   e.g. https://api.example.com/v1
#
VITE_USE_MOCK=true
VITE_API_BASE_URL=http://localhost:3000/api
